// Algorithme permettant de calculer la norme de vecteurs à trois dimensions
real x1;
real y1;
real z1;
real nrkj2_1;
real nrkj_1;

real x2;
real y2;
real z2;
real nrkj2_2;
real nrkj_2;

real x3;
real y3;
real z3;
