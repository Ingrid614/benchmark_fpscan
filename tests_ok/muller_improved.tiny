/*
 * Suite de Muller.
 * Ce benchmark étudie la convergence de la suite :
 *
 * u(n) = 111 - 1130/u(n-1) + 3000/(u(n-2)*u(n-1))
 *
 * La limite théorique est 6, mais les erreurs d'arrondi
 * peuvent progressivement faire dévier la suite.
 *
 * Avant : 2 Cancellations; 0 Absorptions (avec -unroll_n 3)
 * Après : 2 Cancellations; 0 Absorptions
 */


real un_1;
real un_2;
real un_3;
real a;
real b;

real i;

/* u1 = 11/2 */
un_1 = 5.5;

/* u2 = 61/11 */
un_2 = 61. / 11.;

/* on commence au calcul de u3 */
i = 3.;

while (i <= 25.)
{
    /* sauvegarde de u(n-1) */
    un_3 = un_2;

    /* calcul de u(n) */
    a = 111.;
    b = 3000. / (un_1 * un_2) - 1130. / un_2;
    un_2 = a + b;

    /* décalage des termes */
    un_1 = un_3;

    i = i + 1.;
}