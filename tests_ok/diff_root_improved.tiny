/*
 * Essai de correction des problèmes de cancellations et absorption du benchmark diff_root.tiny par réécriture
 * Avant : 3 Cancellations; 9 absorptions
 * Ce benchmark cherche évalue l'expression sqrt(x+1) - sqrt(x) pour des valeurs de x >> 1.
 * L'outil Odyssey nous a proposé l'expression suivante avec une précision de 99,4% : (x <= 1920000.0) ? (sqrt(x + 1.0) - sqrt(x)) : (sqrt(1.0 / x) * 0.5)
 * Après : 0 Cancellations; 3 absorptions
 */
real x1;
real x2;
real x3;
real x4;
real x5;
real y1;
real y2;
real y3;
real y4;
real y5;

x1 = 10000000000000000.;
x2 = 106687256697924407457000.;
x5 = 9.70840407053036266314e+30;

if (x1 <= 1920000.)
{
    y1 = sqrt(x1 + 1.) - sqrt(x1);
}
else
{
    y1 = 0.5 * sqrt(1. / x1);
}

if (x2 <= 1920000.)
{
    y2 = sqrt(x2 + 1.) - sqrt(x2);
}
else
{
    y2 = 0.5 * sqrt(1. / x2);
}

if (x5 <= 1920000.)
{
    y5 = sqrt(x5 + 1.) - sqrt(x5);
}
else
{
    y5 = 0.5 * sqrt(1. / x5);
} 

