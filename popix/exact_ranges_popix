x10 = 0.7745966692414840; // FP64
x11 = 0.7745966692414841; // FP64
x12 = 0.7745966692414842; // FP64

y1  = 5.0 * x1  * x1  - 3.0; // FP32
y2  = 5.0 * x2  * x2  - 3.0; // FP32
y3  = 5.0 * x3  * x3  - 3.0; // FP32
y4  = 5.0 * x4  * x4  - 3.0; // FP32
y5  = 5.0 * x5  * x5  - 3.0; // FP32
y6  = 5.0 * x6  * x6  - 3.0; // FP32
