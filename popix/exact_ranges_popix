y8  = 5.0 * x8  * x8  - 3.0; // FP32
y9  = 5.0 * x9  * x9  - 3.0; // FP32
y10 = 5.0 * x10 * x10 - 3.0; // FP32
y11 = 5.0 * x11 * x11 - 3.0; // FP32
y12 = 5.0 * x12 * x12 - 3.0; // FP32

require_nsb(y1,30);
require_nsb(y2,30);
require_nsb(y3,30);
require_nsb(y4,30);
